get_filename_component(agimus_Franka_CMAKE_DIR "${CMAKE_CURRENT_LIST_FILE}" PATH)

set(THREADS_PREFER_PTHREAD_FLAG ON)
find_package(Threads REQUIRED)

if(NOT TARGET agimus_Franka::Franka)
  include("${agimus_Franka_CMAKE_DIR}/agimus_FrankaTargets.cmake")
endif()

# It is recommended to use target_link_libraries(<target> Franka::Franka) instead.
set(Franka_LIBRARIES agimus_Franka::Franka)
get_target_property(Franka_INCLUDE_DIRS agimus_Franka::Franka INTERFACE_INCLUDE_DIRECTORIES)
